{
  "expo": {
    "name": "Norwaymaxxing",
    "slug": "norwaymaxxing",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "norwaymaxxing",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/norwaymaxxing.icon",
      "bundleIdentifier": "com.norwaymaxxing.norwaymaxxing",
      "supportsTablet": false,
      "appleTeamId": "9N8NPNT7Q4",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Norwaymaxxing's audio engine may access the microphone during interactive RO! rhythm sessions. Microphone audio is not recorded, stored, or shared."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "package": "com.norwaymaxxing.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#DCE8ED",
          "image": "./assets/images/splash-transparent.png",
          "dark": {
            "backgroundColor": "#0D1A2B",
            "image": "./assets/images/splash-transparent.png"
          },
          "imageWidth": 300,
          "resizeMode": "contain"
        }
      ],
      "expo-localization",
      "expo-iap",
      "expo-video",
      "react-native-audio-api"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a4c5fe43-6655-4d7a-bb19-6167727ff104"
      }
    },
    "owner": "conradorr"
  }
}
